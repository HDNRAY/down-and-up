/* 归零按钮组件样式 — 暗红底色 */
.reset-btn {
    width: 88rpx;
    height: 88rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background-color: rgba(180, 30, 30, 0.5);
    box-shadow:
        inset 0 1rpx 4rpx rgba(0, 0, 0, 0.6),
        0 1rpx 0 rgba(255, 255, 255, 0.06);
    transition: transform 0.1s ease;
}

.reset-btn--pressed {
    transform: scale(0.9);
}

.reset-btn__icon {
    font-size: 48rpx;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1;
}
