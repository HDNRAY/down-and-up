<!-- 统计页面 — 3 Panel：大数字 / 河流图 / 数据特点 -->
<view class="stats-page">
  
  <!-- ── 顶部导航 ── -->
  <view class="stats-header">
    <view class="stats-back" bindtap="onBack">
      <text class="back-arrow">←</text>
    </view>
    <text class="stats-header-title">统计</text>
    <view class="stats-header-spacer"></view>
  </view>

  <!-- ════════════════════════════════════
       PANEL 1 — 大数字
       ════════════════════════════════════ -->

  <!-- ── 今日总计数 ── -->
  <view class="stats-total">
    <text class="stats-total-number">{{ todayTotal }}</text>
    <text class="stats-total-label">今日总计</text>
  </view>

  <!-- ── 4 格模式卡片 ── -->
  <view class="stats-cards">
    <view class="stats-card" wx:for="{{ modeCards }}" wx:key="id">
      <text class="card-label" style="color: {{ item.color }}">{{ item.label }}</text>
      <text class="card-value">{{ item.value }}</text>
    </view>
  </view>

  <!-- ── 本周 / 本月 / 今年 — 仅总计 ── -->
  <view class="stats-period">
    <view class="period-header">
      <text class="period-label"></text>
      <text class="period-head" wx:for="{{ periodLabels }}" wx:key="*this">{{ item }}</text>
    </view>
    <view class="period-row">
      <text class="period-mode" style="color: #ffe0a0">总计</text>
      <text class="period-val" wx:for="{{ periodData }}" wx:key="*this">{{ item.total }}</text>
    </view>
  </view>

  <!-- ════════════════════════════════════
       PANEL 2 — 主题河流图
       ════════════════════════════════════ -->
  <view class="stats-river-section">
    <text class="stats-section-title">活动河流</text>
    <canvas id="river-canvas" class="stats-river-canvas" type="2d"></canvas>
  </view>

  <!-- ════════════════════════════════════
       PANEL 3 — 数据特点
       ════════════════════════════════════ -->
  <view class="stats-insights">
    <text class="stats-section-title">数据特点</text>
    <view wx:if="{{ insights.length === 0 }}" class="insights-empty">数据还不够，多用用就有了</view>
    <view class="insight-card" wx:for="{{ insights }}" wx:key="id" wx:for-item="insight">
      <text class="insight-icon">{{ insight.icon }}</text>
      <view class="insight-body">
        <text class="insight-title">{{ insight.title }}</text>
        <text class="insight-desc">{{ insight.desc }}</text>
      </view>
    </view>
  </view>

</view>
