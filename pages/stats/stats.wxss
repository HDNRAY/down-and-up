/* 统计页面样式 — 暗色底 + 琥珀色文字，与主页面统一 */
.stats-page {
    width: 100vw;
    min-height: 100vh;
    background-color: #1a1a2e;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 80rpx 32rpx 48rpx;
    box-sizing: border-box;
}

/* ── 顶部导航 ── */
.stats-header {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 80rpx;
    flex-shrink: 0;
    margin-bottom: 20rpx;
}

.stats-back {
    width: 64rpx;
    height: 64rpx;
    display: flex;
    align-items: center;
    justify-content: center;
}

.back-arrow {
    font-size: 40rpx;
    color: rgba(234, 234, 234, 0.6);
    line-height: 1;
}

.stats-header-title {
    font-size: 32rpx;
    color: rgba(234, 234, 234, 0.5);
    letter-spacing: 4rpx;
}

.stats-header-spacer {
    width: 64rpx;
}

/* ══════════════════════════════════════
   PANEL 1 — 大数字
   ══════════════════════════════════════ */

/* ── 今日总计数 ── */
.stats-total {
    width: 100%;
    text-align: center;
    padding: 40rpx 0 24rpx;
}

.stats-total-number {
    font-size: 100rpx;
    font-weight: bold;
    color: #ffe0a0;
    letter-spacing: 4rpx;
    line-height: 1.1;
}

.stats-total-label {
    font-size: 24rpx;
    color: rgba(255, 224, 160, 0.4);
    margin-top: 8rpx;
    letter-spacing: 6rpx;
}

/* ── 4 格模式卡片 ── */
.stats-cards {
    width: 100%;
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    gap: 16rpx;
    margin-bottom: 32rpx;
}

.stats-card {
    flex: 1;
    background: rgba(255, 255, 255, 0.04);
    border-radius: 16rpx;
    padding: 20rpx 8rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6rpx;
}

.card-label {
    font-size: 30rpx;
    letter-spacing: 2rpx;
    font-weight: bold;
    margin-bottom: 12rpx;
}

.card-value {
    font-size: 36rpx;
    color: #eaeaea;
    font-family: 'Courier New', monospace;
    font-weight: bold;
}

/* ── 本周 / 本月 / 今年 ── */
.stats-period {
    width: 100%;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 16rpx;
    padding: 16rpx 20rpx;
    margin-bottom: 32rpx;
    box-sizing: border-box;
}

.period-header {
    display: flex;
    flex-direction: row;
    align-items: center;
    padding-bottom: 12rpx;
    border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.period-label {
    flex: 1;
}

.period-head {
    flex: 1;
    text-align: right;
    font-size: 22rpx;
    color: rgba(234, 234, 234, 0.35);
    letter-spacing: 2rpx;
}

.period-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    padding: 14rpx 0;
    border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
}

.period-row:last-child {
    border-bottom: none;
}

.period-mode {
    flex: 1;
    font-size: 24rpx;
    font-weight: bold;
    letter-spacing: 2rpx;
}

.period-val {
    flex: 1;
    text-align: right;
    font-size: 24rpx;
    color: rgba(234, 234, 234, 0.75);
    font-family: 'Courier New', monospace;
}

/* ══════════════════════════════════════
   PANEL 2 — 主题河流图
   ══════════════════════════════════════ */

.stats-river-section {
    width: 100%;
    margin-bottom: 32rpx;
}

.stats-river-canvas {
    width: 100%;
    height: 300rpx;
    border-radius: 16rpx;
    background: rgba(255, 255, 255, 0.02);
}

/* ══════════════════════════════════════
   PANEL 3 — 数据特点
   ══════════════════════════════════════ */

.stats-insights {
    width: 100%;
}

.insight-card {
    width: 100%;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 16rpx;
    padding: 24rpx;
    margin-bottom: 14rpx;
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 16rpx;
    box-sizing: border-box;
}

.insight-icon {
    font-size: 40rpx;
    flex-shrink: 0;
    margin-top: 2rpx;
}

.insight-body {
    flex: 1;
    min-width: 0;
}

.insight-title {
    font-size: 26rpx;
    color: #eaeaea;
    font-weight: bold;
    margin-bottom: 6rpx;
    letter-spacing: 1rpx;
}

.insight-desc {
    font-size: 22rpx;
    color: rgba(234, 234, 234, 0.5);
    line-height: 1.5;
}

.insights-empty {
    width: 100%;
    text-align: center;
    padding: 48rpx 0;
    font-size: 24rpx;
    color: rgba(234, 234, 234, 0.2);
}

/* ── 通用 section 标题 ── */
.stats-section-title {
    width: 100%;
    font-size: 26rpx;
    color: rgba(234, 234, 234, 0.45);
    letter-spacing: 4rpx;
    margin-bottom: 16rpx;
}

.history-row--header .history-col {
    color: rgba(234, 234, 234, 0.25);
    font-size: 20rpx;
}
